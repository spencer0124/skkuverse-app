{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "beta": {
      "credentialsSource": "local",
      "channel": "beta"
    },
    "production": {
      "credentialsSource": "local",
      "channel": "production",
      "autoIncrement": true
    }
  }
}
