# =============================================================================
# .easignore — EAS 빌드 전용 ignore (replaces .gitignore during archive)
#
# .gitignore와 동일하되, Firebase 설정 파일은 빌드에 포함시킴:
#   - GoogleService-Info.plist (iOS)
#   - google-services.json (Android)
# =============================================================================

# === From root .gitignore ===

# Dependencies
node_modules/

# Expo
.expo/
dist/

# Native builds (CNG — regenerated by expo prebuild)
ios/
android/

# Environment
.env.local
.env.*.local
# .env는 빌드에 필요 (EXPO_PUBLIC_* 키 포함) — 시크릿이 아닌 public 키만 들어있음

# Firebase credentials — 빌드에 필요하므로 여기서는 제외하지 않음
# GoogleService-Info.plist
# google-services.json

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
*.tsbuildinfo

# Turborepo
.turbo/

# === From apps/mobile/.gitignore ===

# Expo
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

*.pem
!apps/mobile/certs/certificate.pem

# EAS local credentials
credentials.json

app-example
